#----Admin API-----
ADMIN_API_TOKEN=change-me
ADMIN_USER_ID=1
ASS_MODEL=gpt-5.1
LLM_MODEL=gpt-5.1

#----Public Lead Start (Instagram -> in-app chat)-----
PUBLIC_LEAD_START_ENABLED=0
PUBLIC_LEAD_START_KEY=
LEAD_PROXY_PHONE_PREFIX=+999
LEAD_START_TTL_MINUTES=180

#----Auth Email OTP-----
AUTH_EMAIL_TRANSPORT=smtp
# SMTP is the default auth-email transport. For Microsoft 365, use smtp.office365.com:587 with STARTTLS.
AUTH_EMAIL_FROM=
AUTH_EMAIL_REPLY_TO=
AUTH_MS_GRAPH_TENANT_ID=
AUTH_MS_GRAPH_CLIENT_ID=
AUTH_MS_GRAPH_CLIENT_SECRET=
AUTH_MS_GRAPH_SENDER=
AUTH_MS_GRAPH_SCOPE=https://graph.microsoft.com/.default
AUTH_MS_GRAPH_TOKEN_BASE_URL=https://login.microsoftonline.com
AUTH_MS_GRAPH_API_BASE_URL=https://graph.microsoft.com/v1.0
AUTH_MS_GRAPH_TIMEOUT_SECONDS=20
AUTH_EMAIL_DIAGNOSTIC_ON_STARTUP=1
AUTH_EMAIL_DIAGNOSTIC_PROBE=auto
AUTH_SMTP_HOST=smtp.office365.com
AUTH_SMTP_PORT=587
AUTH_SMTP_USERNAME=
AUTH_SMTP_PASSWORD=
AUTH_SMTP_USE_TLS=1
AUTH_SMTP_USE_SSL=0
AUTH_SMTP_TIMEOUT_SECONDS=20

#----Azure Avatar-----
USE_AZURE_AVATAR=0
USE_AZURE_AVATAR_REALTIME_SUMMARY=1
# Avatar can use a separate Speech resource from normal TTS/audio.
AZURE_AVATAR_KEY=
AZURE_AVATAR_REGION=
AZURE_AVATAR_ENDPOINT=
# Fallback speech creds still work if avatar-specific vars are not set.
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=
AZURE_AVATAR_CHARACTER=lisa
AZURE_AVATAR_STYLE=graceful-sitting
AZURE_AVATAR_VOICE=en-GB-SoniaNeural
AZURE_AVATAR_TIMEOUT_SECONDS=180
AZURE_AVATAR_POLL_SECONDS=5
AZURE_AVATAR_REALTIME_SUMMARY_MAX_SESSION_SECONDS=70
AZURE_AVATAR_REALTIME_SUMMARY_MAX_REPLAYS=1
AZURE_AVATAR_GBP_PER_MINUTE=
AZURE_AVATAR_CHARS_PER_MIN=

#----Wearables-----
WEARABLES_ENABLED=1
WEARABLE_OAUTH_STATE_SECRET=
WEARABLE_CALLBACK_BASE_URL=
WEARABLE_OURA_ENABLED=1
OURA_CLIENT_ID=
OURA_CLIENT_SECRET=
OURA_OAUTH_SCOPE=daily personal email
WEARABLE_WHOOP_ENABLED=1
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
WHOOP_OAUTH_SCOPE=offline read:profile read:recovery read:cycles read:sleep
WEARABLE_FITBIT_ENABLED=1
FITBIT_CLIENT_ID=
FITBIT_CLIENT_SECRET=
FITBIT_OAUTH_SCOPE=activity heartrate sleep profile offline_access
WEARABLE_GARMIN_ENABLED=0
GARMIN_CLIENT_ID=
GARMIN_CLIENT_SECRET=
WEARABLE_APPLE_HEALTH_ENABLED=0
